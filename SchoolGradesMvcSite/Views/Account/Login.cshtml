@model LoginViewModel
@{
    ViewData["Title"] = "Вхід";
}
<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="mb-4">Вхід у систему</h2>
                <form asp-action="Login" method="post">
                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label"></label>
                        <input asp-for="UserName" class="form-control" />
                        <span asp-validation-for="UserName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    <div class="form-check mb-3">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label"></label>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Увійти</button>
                </form>
                <hr />
                <div class="mb-3 text-center">Немає акаунта? <a asp-action="Register">Зареєструватися</a></div>
                <div><strong>Тестові акаунти:</strong><br />Адміністратор: <code>admin / admin123</code><br />Користувач: <code>teacher / teacher123</code></div>
            </div>
        </div>
    </div>
</div>
