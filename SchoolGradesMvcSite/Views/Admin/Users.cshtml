@model IEnumerable<UserListItemViewModel>
@{ ViewData["Title"] = "Користувачі"; }
<div class="d-flex justify-content-between align-items-center mb-3"><h2>Користувачі</h2><a class="btn btn-primary" asp-action="CreateUser">Додати користувача</a></div>
<table class="table table-striped table-bordered"><thead><tr><th>ПІБ</th><th>Логін</th><th>Email</th><th>Роль</th><th>Статус</th><th style="width:260px;">Дії</th></tr></thead><tbody>@foreach (var item in Model){<tr><td>@item.FullName</td><td>@item.UserName</td><td>@item.Email</td><td>@item.Role</td><td>@(item.IsActive ? "Активний" : "Неактивний")</td><td><a class="btn btn-sm btn-outline-primary" asp-action="EditUser" asp-route-id="@item.Id">Редагувати</a><form asp-action="ToggleUser" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@item.Id" /><button class="btn btn-sm btn-outline-warning" type="submit">@(item.IsActive ? "Деактивувати" : "Активувати")</button></form><form asp-action="DeleteUser" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@item.Id" /><button class="btn btn-sm btn-outline-danger" type="submit">Видалити</button></form></td></tr>} </tbody></table>
