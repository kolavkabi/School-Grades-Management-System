@model IEnumerable<Grade>
@{ ViewData["Title"] = "Оцінки"; }
<div class="d-flex justify-content-between align-items-center mb-3"><h2>Журнал оцінок</h2><a class="btn btn-primary" asp-action="Create">Додати оцінку</a></div>
<form method="get" class="row g-2 mb-3">
    <div class="col-md-3"><select name="studentId" asp-items="ViewBag.Students" class="form-select"><option value="">Усі учні</option></select></div>
    <div class="col-md-3"><select name="subjectId" asp-items="ViewBag.Subjects" class="form-select"><option value="">Усі предмети</option></select></div>
    <div class="col-md-2"><input type="date" name="dateFrom" value="@ViewBag.DateFrom" class="form-control" /></div>
    <div class="col-md-2"><input type="date" name="dateTo" value="@ViewBag.DateTo" class="form-control" /></div>
    <div class="col-md-2"><button class="btn btn-outline-primary w-100">Фільтрувати</button></div>
</form>
<table class="table table-striped table-bordered"><thead><tr><th>Дата</th><th>Учень</th><th>Клас</th><th>Предмет</th><th>Вчитель</th><th>Оцінка</th><th>Коментар</th><th style="width:320px;">Дії</th></tr></thead><tbody>
@foreach (var item in Model){<tr><td>@item.DateAssigned.ToString("yyyy-MM-dd")</td><td>@item.Student?.FullName</td><td>@item.Student?.ClassName</td><td>@item.Subject?.Name</td><td>@item.Teacher?.FullName</td><td><span class="badge bg-primary">@item.Value</span></td><td>@item.Comment</td><td class="text-nowrap"><a class="btn btn-sm btn-outline-info" asp-action="Details" asp-route-id="@item.Id">Деталі</a><a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Редагувати</a><a class="btn btn-sm btn-outline-secondary" asp-action="EditComment" asp-route-id="@item.Id">Коментар</a><a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Видалити</a></td></tr>}
</tbody></table>
