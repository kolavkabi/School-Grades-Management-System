@model IEnumerable<Grade>
@{ ViewData["Title"] = "Історія оцінок"; var student = ViewBag.Student as Student; }
<div class="card shadow-sm"><div class="card-body"><h2>Історія оцінок: @student?.FullName</h2><p><strong>Клас:</strong> @student?.ClassName</p><table class="table table-striped"><thead><tr><th>Дата</th><th>Предмет</th><th>Вчитель</th><th>Оцінка</th><th>Коментар</th><th>Дія</th></tr></thead><tbody>@foreach (var g in Model){<tr><td>@g.DateAssigned.ToString("yyyy-MM-dd")</td><td>@g.Subject?.Name</td><td>@g.Teacher?.FullName</td><td>@g.Value</td><td>@g.Comment</td><td><a class="btn btn-sm btn-outline-secondary" asp-action="EditComment" asp-route-id="@g.Id">Коментар</a></td></tr>}</tbody></table><a class="btn btn-secondary" asp-controller="Students" asp-action="Index">Назад</a></div></div>
