@model Grade
<div class="card shadow-sm"><div class="card-body"><h2>@ViewData["Title"]</h2><form method="post"><div asp-validation-summary="ModelOnly" class="text-danger"></div><input asp-for="Id" type="hidden" /><div class="row g-3"><div class="col-md-4"><label asp-for="StudentId" class="form-label"></label><select asp-for="StudentId" asp-items="ViewBag.Students" class="form-select"></select></div><div class="col-md-4"><label asp-for="SubjectId" class="form-label"></label><select asp-for="SubjectId" asp-items="ViewBag.Subjects" class="form-select"></select></div><div class="col-md-4"><label asp-for="TeacherId" class="form-label"></label><select asp-for="TeacherId" asp-items="ViewBag.Teachers" class="form-select"></select></div><div class="col-md-3"><label asp-for="Value" class="form-label"></label><input asp-for="Value" class="form-control" /><span asp-validation-for="Value" class="text-danger"></span></div><div class="col-md-3"><label asp-for="DateAssigned" class="form-label"></label><input asp-for="DateAssigned" class="form-control" /><span asp-validation-for="DateAssigned" class="text-danger"></span></div><div class="col-md-12"><label asp-for="Comment" class="form-label"></label><textarea asp-for="Comment" class="form-control"></textarea></div></div><div class="mt-4 d-flex gap-2"><button class="btn btn-primary" type="submit">Зберегти</button><a asp-action="Index" class="btn btn-secondary">Назад</a></div></form></div></div>
