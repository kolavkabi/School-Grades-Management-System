<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - School Grades Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">School Grades</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Головна</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About">Про систему</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Subjects" asp-action="Index">Предмети</a></li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Students" asp-action="Index">Учні</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Grades" asp-action="Index">Оцінки</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Reports" asp-action="Index">Звіти</a></li>
                    }
                    @if (User.IsInRole("Administrator"))
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Teachers" asp-action="Index">Вчителі</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Dashboard">Адмін</a></li>
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item"><span class="navbar-text me-3">@User.Identity.Name</span></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="ChangePassword">Змінити пароль</a></li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-light btn-sm">Вийти</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item me-2"><a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Register">Реєстрація</a></li>
                        <li class="nav-item"><a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Login">Увійти</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container pb-4">
        @if (TempData["Success"] is string success)
        {
            <div class="alert alert-success">@success</div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="alert alert-danger">@error</div>
        }

        @RenderBody()
    </div>

    <footer class="border-top footer text-muted py-3">
        <div class="container">School Grades Management System</div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
