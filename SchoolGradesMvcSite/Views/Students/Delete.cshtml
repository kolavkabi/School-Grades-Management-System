@model Student
@{ ViewData["Title"] = "Видалити учня"; }
<div class="card shadow-sm"><div class="card-body"><h2>Видалити учня</h2><p>Ви впевнені, що хочете видалити <strong>@Model.FullName</strong>?</p><form asp-action="Delete" method="post"><input type="hidden" asp-for="Id" /><button type="submit" class="btn btn-danger">Видалити</button> <a asp-action="Index" class="btn btn-secondary">Скасувати</a></form></div></div>
