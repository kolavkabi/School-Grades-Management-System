@{ ViewData["Title"] = "Імпорт учнів"; }
<div class="card shadow-sm"><div class="card-body"><h2>Імпорт учнів із CSV</h2><p>Формат: <code>FirstName,LastName,ClassName,DateOfBirth</code></p><form asp-action="Import" method="post" enctype="multipart/form-data">@Html.AntiForgeryToken()<div asp-validation-summary="ModelOnly" class="text-danger"></div><div class="mb-3"><input type="file" name="csvFile" class="form-control" accept=".csv" /></div><button type="submit" class="btn btn-primary">Імпортувати</button> <a asp-action="Index" class="btn btn-secondary">Назад</a></form></div></div>
