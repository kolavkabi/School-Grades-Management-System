@model IEnumerable<Student>
@{
    ViewData["Title"] = "Учні";
    var classes = ViewBag.Classes as IEnumerable<string> ?? Enumerable.Empty<string>();
    string? currentClass = ViewBag.ClassName as string;
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Учні</h2>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-action="Import">Імпорт CSV</a>
        <a class="btn btn-outline-success" asp-action="ExportCsv">Експорт CSV</a>
        <a class="btn btn-primary" asp-action="Create">Додати учня</a>
    </div>
</div>
<form method="get" class="row g-2 mb-3">
    <div class="col-md-4"><input name="search" value="@ViewBag.Search" class="form-control" placeholder="Пошук за ім’ям або прізвищем" /></div>
    <div class="col-md-3">
        <select name="className" class="form-select">
            <option value="">Усі класи</option>
            @foreach (var cls in classes)
            {
                if (currentClass == cls)
                {
                    <option value="@cls" selected>@cls</option>
                }
                else
                {
                    <option value="@cls">@cls</option>
                }
            }
        </select>
    </div>
    <div class="col-md-2"><button class="btn btn-outline-primary w-100">Фільтрувати</button></div>
</form>
<table class="table table-striped table-bordered align-middle">
    <thead><tr><th>ПІБ</th><th>Клас</th><th>Дата народження</th><th>Статус</th><th style="width: 320px;">Дії</th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.FullName</td>
            <td>@item.ClassName</td>
            <td>@item.DateOfBirth.ToString("yyyy-MM-dd")</td>
            <td>@(item.IsActive ? "Активний" : "Неактивний")</td>
            <td class="text-nowrap">
                <a class="btn btn-sm btn-outline-info" asp-action="Details" asp-route-id="@item.Id">Деталі</a>
                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Редагувати</a>
                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Видалити</a>
                <a class="btn btn-sm btn-outline-secondary" asp-controller="Grades" asp-action="StudentHistory" asp-route-id="@item.Id">Історія</a>
                @if (User.IsInRole("Administrator"))
                {
                    <form asp-action="ToggleStatus" asp-route-id="@item.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-warning">@(item.IsActive ? "Деактивувати" : "Активувати")</button>
                    </form>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
