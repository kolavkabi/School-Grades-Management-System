@model IEnumerable<Subject>
@{ ViewData["Title"] = "Предмети"; }
<div class="d-flex justify-content-between align-items-center mb-3"><h2>Предмети</h2>@if (User.Identity?.IsAuthenticated == true){<a class="btn btn-primary" asp-action="Create">Додати предмет</a>}</div>
<table class="table table-striped table-bordered"><thead><tr><th>Назва</th><th>Опис</th><th>Години</th><th>Статус</th><th style="width:240px;">Дії</th></tr></thead><tbody>
@foreach (var item in Model)
{
    <tr><td>@item.Name</td><td>@item.Description</td><td>@item.WeeklyHours</td><td>@(item.IsActive ? "Активний" : "Неактивний")</td><td><a class="btn btn-sm btn-outline-info" asp-action="Details" asp-route-id="@item.Id">Деталі</a>@if (User.Identity?.IsAuthenticated == true){<a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Редагувати</a><a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Видалити</a>}</td></tr>
}
</tbody></table>
