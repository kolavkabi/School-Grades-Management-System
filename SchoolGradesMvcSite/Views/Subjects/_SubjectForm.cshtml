@model Subject
<div class="card shadow-sm"><div class="card-body"><h2>@ViewData["Title"]</h2><form method="post"><div asp-validation-summary="ModelOnly" class="text-danger"></div><input asp-for="Id" type="hidden" /><div class="row g-3"><div class="col-md-6"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger"></span></div><div class="col-md-6"><label asp-for="WeeklyHours" class="form-label"></label><input asp-for="WeeklyHours" class="form-control" /><span asp-validation-for="WeeklyHours" class="text-danger"></span></div><div class="col-md-12"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control"></textarea><span asp-validation-for="Description" class="text-danger"></span></div><div class="col-md-4 d-flex align-items-end"><div class="form-check"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label"></label></div></div></div><div class="mt-4 d-flex gap-2"><button class="btn btn-primary" type="submit">Зберегти</button><a asp-action="Index" class="btn btn-secondary">Назад</a></div></form></div></div>
