@model TeacherAssignSubjectViewModel
@{ ViewData["Title"] = "Призначити предмет"; }
<div class="card shadow-sm"><div class="card-body"><h2>Призначити предмет</h2><p><strong>Вчитель:</strong> @Model.TeacherName</p><form asp-action="AssignSubject" method="post">@Html.AntiForgeryToken()<input asp-for="TeacherId" type="hidden" /><div class="mb-3"><label asp-for="SubjectId" class="form-label"></label><select asp-for="SubjectId" asp-items="Model.Subjects" class="form-select"></select></div><button class="btn btn-primary" type="submit">Призначити</button> <a asp-action="Details" asp-route-id="@Model.TeacherId" class="btn btn-secondary">Назад</a></form></div></div>
