@model Teacher
@{ ViewData["Title"] = "Видалити вчителя"; }
<div class="card shadow-sm"><div class="card-body"><h2>Видалити вчителя</h2><p>Видалити <strong>@Model.FullName</strong>?</p><form asp-action="Delete" method="post"><input type="hidden" asp-for="Id" /><button class="btn btn-danger" type="submit">Видалити</button> <a asp-action="Index" class="btn btn-secondary">Скасувати</a></form></div></div>
