@model Teacher
@{ ViewData["Title"] = "Деталі вчителя"; }
<div class="card shadow-sm mb-3"><div class="card-body"><h2>@Model.FullName</h2><p><strong>Email:</strong> @Model.Email</p><p><strong>Статус:</strong> @(Model.IsActive ? "Активний" : "Неактивний")</p><a class="btn btn-primary" asp-action="AssignSubject" asp-route-id="@Model.Id">Призначити предмет</a></div></div>
<div class="card shadow-sm mb-3"><div class="card-body"><h4>Предмети</h4><table class="table table-sm"><thead><tr><th>Назва</th><th></th></tr></thead><tbody>@foreach (var ts in Model.TeacherSubjects){<tr><td>@ts.Subject?.Name</td><td><form asp-action="RemoveSubject" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="teacherId" value="@Model.Id" /><input type="hidden" name="subjectId" value="@ts.SubjectId" /><button class="btn btn-sm btn-outline-danger" type="submit">Відкріпити</button></form></td></tr>}</tbody></table></div></div>
<div class="card shadow-sm"><div class="card-body"><h4>Оцінки, виставлені вчителем</h4><table class="table table-sm"><thead><tr><th>Дата</th><th>Предмет</th><th>Оцінка</th></tr></thead><tbody>@foreach (var g in Model.Grades.OrderByDescending(x => x.DateAssigned)){<tr><td>@g.DateAssigned.ToString("yyyy-MM-dd")</td><td>@g.Subject?.Name</td><td>@g.Value</td></tr>}</tbody></table><a asp-action="Index" class="btn btn-secondary">Назад</a></div></div>
