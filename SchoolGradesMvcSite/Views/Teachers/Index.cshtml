@model IEnumerable<Teacher>
@{ ViewData["Title"] = "Вчителі"; }
<div class="d-flex justify-content-between align-items-center mb-3"><h2>Вчителі</h2><a class="btn btn-primary" asp-action="Create">Додати вчителя</a></div>
<table class="table table-striped table-bordered"><thead><tr><th>ПІБ</th><th>Email</th><th>Статус</th><th>Предмети</th><th style="width:250px;">Дії</th></tr></thead><tbody>
@foreach (var item in Model){<tr><td>@item.FullName</td><td>@item.Email</td><td>@(item.IsActive ? "Активний" : "Неактивний")</td><td>@string.Join(", ", item.TeacherSubjects.Select(x => x.Subject!.Name))</td><td><a class="btn btn-sm btn-outline-info" asp-action="Details" asp-route-id="@item.Id">Деталі</a><a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Редагувати</a><a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Видалити</a></td></tr>}
</tbody></table>
